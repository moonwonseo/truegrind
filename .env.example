# Roboflow — get your key at app.roboflow.com → Settings → Roboflow API
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Cloudflare R2 credentials (S3-compatible)
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Found at: Cloudflare Dashboard → Workers & Pages → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

# Found at: Cloudflare Dashboard → top-right account dropdown → Account ID
R2_ACCOUNT_ID=your_cloudflare_account_id_here

# The R2 bucket name you created
R2_BUCKET_NAME=truegrind-dataset

# Auto-derived from account ID — you can leave this as-is
R2_ENDPOINT_URL=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# Key prefix inside the bucket (acts like a folder). Change if you want.
R2_PREFIX=ds

# Optional: public bucket URL for credential-free downloads.
# Enable at: Cloudflare → R2 → your bucket → Settings → Public Access
# Format: https://pub-<hash>.r2.dev  OR  https://your-custom-domain.com
# If set, anyone can run `uv run r2-sync download` without R2 credentials.
R2_PUBLIC_URL=
