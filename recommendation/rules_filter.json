    "balanced_signals": [
      "balanced",
      "sweet",
      "good",
      "smooth",
      "clean",
      "juicy",
      "complex",
      "rich",
      "round",
      "floral",
      "fruity",
      "chocolatey",
      "nutty",
      "caramel"
