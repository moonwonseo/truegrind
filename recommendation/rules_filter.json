  },
  "messages": {
    "balanced": "Your brew seems balanced. Keep this setting as your reference point.",
    "mixed": "This sounds like uneven extraction more than a simple grind-size issue.",
    "mixed_secondary": "Keep grind the same for one more brew. Reduce or standardize agitation, pour more evenly, and watch for stalled drawdown.",
    "fallback": "Not enough signal for a confident recommendation yet. Rebrew with the same recipe, re-photograph, and add taste notes plus drawdown time."
