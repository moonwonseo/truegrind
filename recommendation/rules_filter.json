{
  "schema_version": "2.0",
  "layer_name": "true_grind_filter_recommendation",
  "purpose": "Recommendation rules for grind adjustment, considering brew variables, distribution quality, and taste feedback.",
  "scope": {
    "supported_brew_methods": [
      "pour_over",
      "french_press",
      "aeropress",
      "drip",
      "moka_pot"
    ],
    "supported_grinder_types": [
      "stepped"
    ],
    "unsupported_grinder_types": [
      "blade"
    ]
  },
  "inputs": {
    "required": [
      "current_d50",
      "current_setting",
      "fitted_slope",
      "dial_range_min",
      "dial_range_max",
      "taste_feedback"
    ],
    "optional": [
      "psd_stats",
      "brew_method",
      "water_temp_c",
      "filter_type",
      "extraction_time_s",
      "num_pours",
      "dose_g",
      "water_g",
      "agitation_level",
      "grinder_model"
    ]
  },
  "constants": {
    "target_brew_method": "filter",
    "target_d50_um": 600,
    "absolute_tolerance_um": 40,
    "default_secondary_step": {
      "temperature_c": 2,
      "ratio_delta_water_g": 15,
      "contact_time_s": 10
    }
  },
  "brew_methods": {
